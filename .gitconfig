[user]
  name = Peter Sukhenko
  email = 7243796+pezzu@users.noreply.github.com


[alias]
  md = difftool --tool=meld --dir-diff --no-prompt
  mds = difftool --tool=meld --dir-diff --no-prompt --staged
  br = branch --sort=-committerdate
  ci = commit
  ca = commit --all
  co = checkout
  glog = log --all --pretty='format:%d %Cgreen%h%Creset %an - %s' --graph
  lg = log --oneline --color=always --pretty=format:'%C(yellow)%h %Cgreen%ad %C(blue)%<(6)%al%Creset %s' --date=short -n 50
  lgf = log --oneline --color --pretty=format:'%C(yellow)%h %Cgreen%ad %C(blue)%<(6)%al%Creset %s' --date=short --name-status -n 50
  rb = rebase
  st = status


[core]
  pager = less -F -X


[credential]
  helper = store


[diff]
  context = 10


[difftool]
  prompt = false


[difftool "meld"]
  cmd = meld "$LOCAL" "$REMOTE"


[difftool "vimdiff"]
  cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'


[filter "lfs"]
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f


[init]
  defaultBranch = main


[push]
  autoSetupRemote = true
